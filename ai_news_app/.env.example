# Copy this file to .env and fill in your values before running docker compose.

# ── Gotify ───────────────────────────────────────────────────────────────────
# URL of the Gotify service reachable from inside Docker
GOTIFY_URL=http://gotify:80/message

# Token for the app in Gotify: Apps → Add App → copy the token here
GOTIFY_TOKEN=your_gotify_app_token_here

# Gotify admin password — set BEFORE the first `docker compose up`.
# Changing it afterwards has no effect (stored in the DB).
GOTIFY_DEFAULTUSER_PASS=change_me_before_first_run

# ── Time ─────────────────────────────────────────────────────────────────────
TZ=Europe/Warsaw
